# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=cybertwin_jwt_secret_key_change_in_production
JWT_EXPIRY=24h

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Risk Thresholds
RISK_WARN_THRESHOLD=31
RISK_BLOCK_THRESHOLD=61

# Behavioral Twin
BASELINE_LEARNING_RATE=0.1
BASELINE_SAFE_DEVIATION=0.5
MIN_SESSIONS_FOR_BASELINE=3
